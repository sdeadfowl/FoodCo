    @RenderSection("scripts", required: false)
    <script>
        $(function () {
            let NotificationsDisabled = false; // On/Off

            function checkNotifications() {
                $.ajax({
                    url: "/Account/UserHasNotifications",
                    dataType: "text",
                    success: (hasNotifications) => {
                        console.log("Has notification:", JSON.parse(hasNotifications));
                        if (JSON.parse(hasNotifications)) {
                            $("#notificationBubble").addClass("blink-bubble blink").show();
                        } else {
                            $("#notificationBubble").removeClass("blink-bubble blink").hide();
                        }
                    },
                    error: (err) => {
                        console.error("Error fetching notifications:", err);
                    }
                });
            }

            if (!NotificationsDisabled) {
                checkNotifications();
                setInterval(checkNotifications, 10 * 1000);
            }


        });
        document.addEventListener('click', function (event) {
            let resultsContainer = document.getElementById('searchResults');
            let searchInput = document.getElementById('userSearch');


            if (!resultsContainer.contains(event.target) && !searchInput.contains(event.target)) {
                resultsContainer.style.display = 'none';
            }
        });
        function searchUsers() {
            let query = document.getElementById('userSearch').value.trim();
            let resultsContainer = document.getElementById('searchResults');

            if (query.length === 0) {
                resultsContainer.innerHTML = '';
                resultsContainer.style.display = 'none';
                return;
            }
            else {
                resultsContainer.style.display = 'flex';
            }

            fetch(`/Account/SearchUsers?query=${encodeURIComponent(query)}`)
                .then(response => {
                    if (!response.ok) {
                        throw new Error(response.status);
                    }
                    return response.json();
                })
                .then(users => {
                    if (Array.isArray(users) && users.length > 0) {
                        let results = users.map(user => `
                            <a href="/Account/Profile?username=${user.Username}">
                                    <div class="search-results-card pointer">
                                    <img src="${user.ProfilePicture}" alt="${user.Username}" class="UserMediumAvatar" />
                                        <div class="search-results-content">
                                            <p><strong>@@${user.Username}</strong></p>
                                        </div>
                                    </div>
                            </a>



                            `).join('');
                        resultsContainer.innerHTML = results;
                    } else {
                        resultsContainer.innerHTML = (
                            '<p><strong>Aucun résultat</strong></p>');
                    }
                })
                .catch(error => {
                    resultsContainer.innerHTML = '<p><strong>Une erreur est survenue</strong></p>';
                });
        }

    </script>

