    <script>
        function toggleDropdown(event) {
            event.preventDefault();
            event.stopPropagation();
            var dropdown = event.currentTarget.parentElement;
            dropdown.classList.toggle('show');
        }

        // Close the dropdown when clicking outside
        document.addEventListener('click', function (event) {
            var dropdowns = document.querySelectorAll('.main-nav-item.profile-dropdown.show');
            dropdowns.forEach(function (dropdown) {
                if (!dropdown.contains(event.target)) {
                    dropdown.classList.remove('show');
                }
            });
        });


    </script>
    <script src="https://kit.fontawesome.com/8629bd9561.js" crossorigin="anonymous"></script>
