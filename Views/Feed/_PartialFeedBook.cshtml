@{
    Layout = null;
    @model List<FoodCo.Models.Recipe>
    var _userId = Session["currentUserId"]?.ToString();
}

<section class="feed">
    <ul class="feed-list" id="feed-list">
        @if (Model != null && Model.Any())
        {
            foreach (var r in Model)
            {


                <li class="feed-item pointer">

                    <article class="foodco-item">
                        <img class="profile-image" src="@(r.User.ProfilePicturePath != null ? r.User.ProfilePicturePath : "default-profile-image-base64")" alt="profile-image">
                        <header class="foodco-item-info u-flex">
                            <a class="foodco-item-info-user" href="@Url.Action("Profile", "Account", new { username = r.User.UserName })">
                                <span class="common-title">@r.User.Name</span>
                                <span class="usercode">@@@r.User.UserName.ToLower()</span>
                            </a>
                            <time datetime="@r.Date.ToString("yyyy/MM/dd")">
                                @r.Date.ToString("MM/dd/yyyy", System.Globalization.CultureInfo.InvariantCulture)
                            </time>


                            <div class="u-flex u-left-margin-auto" style="align-items: center;">
                                @if (r.UserId == _userId)
                                {
                                    <div class="feed-item-options-dropdown u-flex u-margin-start-auto" style="position: relative;">
                                        <button class="icon-button" style="--icon-button-size:27px;" onclick="toggleFeedItemDropdown(this)">
                                            <span class="icon fa fas fa-ellipsis-h"></span>
                                        </button>
                                        <ul class="feed-item-dropdown-menu feed-item-options" style="position: absolute; right: 0; top: 100%; display: none;">
                                            <li class="feed-item-dropdown-item">
                                                <a href="@Url.Action("Details", "Recipe", new { id = r.Id })">Afficher les détails</a>
                                            </li>
                                            <li class="feed-item-dropdown-item">
                                                <a href="@Url.Action("Edit", "Recipe", new { id = r.Id })">Modifier</a>
                                            </li>
                                            <li class="feed-item-dropdown-item">
                                                @using (Html.BeginForm("Delete", "Recipe", FormMethod.Post, new { @onsubmit = "return confirm('Êtes-vous sûr de vouloir supprimer cette recette?');" }))
                                                {
                                                    @Html.AntiForgeryToken()
                                                    @Html.Hidden("id", r.Id)
                                                    <button type="submit" class="dropdown-link">Supprimer</button>
                                                }
                                            </li>
                                        </ul>
                                    </div>
                                }
                                else
                                {
                                    <div class="feed-item-options-dropdown u-flex u-margin-start-auto" style="position: relative;">
                                        <button class="icon-button" style="--icon-button-size:27px;" onclick="toggleFeedItemDropdown(this)">
                                            <span class="icon fa fas fa-ellipsis-h"></span>
                                        </button>
                                        <ul class="feed-item-dropdown-menu feed-item-options" style="position: absolute; right: 0; top: 100%; display: none;">
                                            <li class="feed-item-dropdown-item">
                                                <a href="@Url.Action("Details", "Recipe", new { id = r.Id })">Afficher les détails</a>
                                            </li>
                                        </ul>
                                    </div>
                                }
                            </div>

                        </header>
                        <div class="common-content" onclick="location.href = '@Url.Action("Details", "Recipe", new { id = r.Id })' ">
                            <div class="review-container">
                                <div class="review-options">
                                    @if (r.ReviewCount() < 1)
                                    {
                                        <p class="reset-spacing total-reviews">Aucun review</p>
                                    }
                                    else
                                    {
                                        <div>
                                            @for (int f = 0; f < (int)Math.Floor(r.AverageRating()); f++)
                                            {
                                                <span class="icon-stars reset-spacing fa fa-star checked"></span>
                                            }
                                            @if (r.AverageRating() - Math.Floor(r.AverageRating()) >= 0.5)
                                            {
                                                <span class="icon-stars reset-spacing fa fa-star-half"></span>
                                            }
                                        </div>
                                        <p class="reset-spacing total-reviews">(@r.ReviewCount())</p>
                                    }
                                    <div class="tag-container u-flex u-left-margin-auto">
                                        <p class="tag reset-spacing">
                                            @(string.IsNullOrEmpty(r.Tag) ? string.Empty : char.ToUpper(r.Tag[0]) + r.Tag.Substring(1))
                                        </p>
                                    </div>
                                </div>
                            </div>

                            <h2>@r.Name</h2>
                            <p>@r.Description</p>

                            @if (r.ContentPath != null)
                            {
                                var fileExtension = System.IO.Path.GetExtension(r.ContentPath).ToLower();
                                if (fileExtension == ".jpg" || fileExtension == ".jpeg" || fileExtension == ".png" || fileExtension == ".gif")
                                {
                                    <img class="content-image" src="@r.ContentPath">
                                }
                                else if (fileExtension == ".mp4" || fileExtension == ".webm" || fileExtension == ".ogg")
                                {
                                    <video class="content-video" controls onclick="event.stopPropagation()">
                                        <source src="@r.ContentPath" type="video/@fileExtension.Substring(1)">
                                    </video>
                                }
                            }
                        </div>
                        <ul class="message-options u-flex u-space-between">
                            <li class="message-options-item">
                                <label>
                                    <button class="icon-button comment" onclick="event.stopPropagation(); toggleCommentBox('@r.Id', 'recipe');"><span class="icon fa-regular fa-comment"></span></button>
                                    <span class="text"></span>
                                </label>
                            </li>
                            <li class="message-options-item">
                                <label>
                                    @if (r.Likes.Any(l => l.UserId == _userId))
                                    {
                                        <button class="icon-button like" id="like-btn-@r.Id" onclick="event.stopPropagation(); toggleRecipeLike('@r.Id')"><span id="like-text-@r.Id" class="icon fa-solid fa-heart liked"></span></button>
                                    }
                                    else
                                    {
                                        <button class="icon-button like" id="like-btn-@r.Id" onclick="event.stopPropagation(); toggleRecipeLike('@r.Id')"><span id="like-text-@r.Id" class="icon fa-regular fa-heart"></span></button>
                                    }
                                    <span class="text likes-count">@r.Likes.Count()</span>
                                </label>
                            </li>
                            <li class="message-options-item">
                                <label>
                                        <button class="icon-button like" id="Book-@r.Id" onclick="RemoveRecipeFromBook('@r.Id')"><span class="icon fa-solid fa-bookmark"></span></button>
                                </label>
                            </li>

                            <li class="message-options-item">
                                <label>
                                    <button class="icon-button" onclick="event.stopPropagation(); CopierLienPublication(@r.Id, true)"><span class="icon">🔗</span></button>
                                    <span class="text"></span>
                                </label>
                            </li>
                        </ul>
                    </article>
                    <section class="comment-message-box u-hide-border u-hide" onlick="event.stopPropagation();" id="comment-box-@r.Id">
                        <div class="profile-image-wrap">
                            <img class="profile-image" src="@Url.Action("Photo", "Account")" alt="">
                        </div>
                        <div class="message-box-content">
                            <textarea class="message-box-text-area" id="commentText-@r.Id" placeholder="Écrivez un commentaire..."></textarea>
                       
                            <button type="button" id="remove-preview" class="remove-preview-button u-hide">&times;</button>
                            <p class="message-alert" id="message-alert-@r.Id"></p>
                        </div>
                        <nav class="message-box-nav u-flex">
                            <button type="button" class="common-button u-margin-start-auto" onclick="submitComment('@r.Id', 'recipe')"><span class="text">Publier</span></button>
                        </nav>
                    </section>
                </li>
            }


        }
    </ul>
</section>
