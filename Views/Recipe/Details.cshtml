@model FoodCo.Models.Recipe

@{
    ViewBag.Title = "Détails";
    Layout = "~/Views/Shared/_LoggedInLayout.cshtml";
    var _userId = Session["currentUserId"]?.ToString();
}

@if (Model != null)
{
    <header class="main-header">
        <button class="icon-button icon fa fa-arrow-left" onclick="window.history.back()"><span class="icon"></span></button>
        <div class="main-header-content">
            <h1 class="section-title">@ViewBag.Title</h1>
        </div>
        <button class="icon-button u-margin-start-auto" aria-label="Top foodcos on"><span class="icon">✨</span></button>
    </header>
    <ul class="recipe-detail" id="recipe-detail">
        <li class="feed-item">

            <article class="foodco-item-details">
                <img class="profile-image" src="@(Model.User.ProfilePicturePath != null ? Model.User.ProfilePicturePath : "default-profile-image-base64")" alt="profile-image">
                <header class="foodco-item-info-details u-flex">
                    <a class="foodco-item-info-user-details" href="@Url.Action("Profile","Account",new {username = Model.User.UserName})">
                        <span class="common-title">@Model.User.Name</span>
                        <span class="usercode">@Model.User.UserName.ToLower()</span>
                    </a>
                    <time datetime="@Model.Date.ToString("yyyy/MM/dd")">
                        @Model.Date.ToString("MM/dd/yyyy", System.Globalization.CultureInfo.InvariantCulture)
                    </time>


                    <div class="u-flex u-left-margin-auto" style="align-items: center;">
                        @*<div class="u-flex u-left-margin-auto" style="align-items: center; flex-direction: column; gap:0.5em;">
                                <div class="u-flex" style="align-items: center;">
                                    @for (int f = 0; f < (int)Math.Floor(Math.Round(4.5, 1)); f++)
                                    {
                                        <span class="icon-stars reset-spacing fa fa-star checked"></span>
                                    }
                                    @if (4.5 % 1 != 0)
                                    {
                                        <span class="icon-stars reset-spacing fa fa-star-half"></span>
                                    }
                                    <p class="reset-spacing total-reviews">(512)</p>
                                </div>
                                <div class="tag-container u-flex u-left-margin-auto">
                                    <p class="tag reset-spacing">
                                        @(string.IsNullOrEmpty(r.Tag) ? string.Empty : char.ToUpper(r.Tag[0]) + r.Tag.Substring(1))
                                    </p>
                                </div>
                            </div>*@
                        @if (Model.UserId == _userId)
                        {
                            <div class="feed-item-options-dropdown u-flex u-margin-start-auto" style="position: relative;">
                                <button class="icon-button" style="--icon-button-size:27px;" onclick="toggleFeedItemDropdown(this)">
                                    <span class="icon fa fas fa-ellipsis-h"></span>
                                </button>
                                <ul class="feed-item-dropdown-menu feed-item-options" style="position: absolute; right: 0; top: 100%; display: none;">
                                    <li class="feed-item-dropdown-item">
                                        <a href="@Url.Action("Edit", "Recipe", new { id = Model.Id })">Modifier</a>
                                    </li>
                                    <li class="feed-item-dropdown-item">
                                        @using (Html.BeginForm("Delete", "Recipe", FormMethod.Post, new { id = Model.Id, onsubmit = "return confirm('Êtes-vous sûr de vouloir supprimer cette recette?');" }))
                                        {
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="dropdown-link">Supprimer</button>
                                        }
                                    </li>
                                </ul>
                            </div>
                        }
                        @*<div>
                                <button class="icon-button u-flex u-left-margin-auto" style="--icon-button-size:27px;"><span class="icon icon-arrow-down u-margin-auto"></span></button>
                            </div>*@
                    </div>

                </header>
                <div class="common-content">
                    <div class="review-container">
                        <div class="review-options">
                            @if (Model.ReviewCount() < 1)
                            {
                                <p class="reset-spacing total-reviews">Aucun review</p>
                            }
                            else
                            {
                                <div>
                                    @for (int f = 0; f < (int)Math.Floor(Model.AverageRating()); f++)
                                    {
                                        <span class="icon-stars reset-spacing fa fa-star checked"></span>
                                    }
                                    @if (Model.AverageRating() - Math.Floor(Model.AverageRating()) >= 0.5)
                                    {
                                        <span class="icon-stars reset-spacing fa fa-star-half"></span>
                                    }
                                </div>
                                <p class="reset-spacing total-reviews">(@Model.ReviewCount())</p>
                            }
                            <div class="tag-container u-flex u-left-margin-auto">
                                <p class="tag reset-spacing">
                                    @(string.IsNullOrEmpty(Model.Tag) ? string.Empty : char.ToUpper(Model.Tag[0]) + Model.Tag.Substring(1))
                                </p>
                            </div>
                        </div>
                        @if (ViewBag.HasReviewed)
                        {
                            <a class="review-link text blocked" style="cursor: not-allowed;" title="Vous avez déjà évalué cette recette" style="cursor: not-allowed; color: grey; pointer-events: none;">
                                Vous avez déjà évalué cette recette
                            </a>
                        }
                        else
                        {
                            <a class="review-link text" id="reviewBtn" title="Évaluer cette recette">Évaluer cette recette</a>
                        }
                    </div>
                    <h2>@Model.Name</h2>
                    <p>@Model.Description</p>


                    @*@if (r.ContentPath != null)
                        {
                            <img class="content-image" src="@r.ContentPath" alt="Post content">
                        }*@
                    @if (Model.ContentPath != null)
                    {
                        var fileExtension = System.IO.Path.GetExtension(Model.ContentPath).ToLower();
                        if (fileExtension == ".jpg" || fileExtension == ".jpeg" || fileExtension == ".png" || fileExtension == ".gif")
                        {
                            <img class="content-image" src="@Model.ContentPath">
                        }
                        else if (fileExtension == ".mp4" || fileExtension == ".webm" || fileExtension == ".ogg")
                        {
                            <video class="content-video" controls onclick="event.stopPropagation()">
                                <source src="@Model.ContentPath" type="video/@fileExtension.Substring(1)">
                            </video>
                        }
                    }
                    <br />
                    <button class="recipe-accordion">Ingrédients</button>
                    <div class="recipe-accordion-container">
                        @if (Model.Ingredients != null && Model.Ingredients.Any())
                        {
                            <ul class="recipe-accordion-list">
                                @{
                                    int i = 0;
                                }
                                @foreach (var ingredient in Model.Ingredients)
                                {
                                    var measurement = ingredient.Measurements.ToLower();
                                    if (measurement == "unit")
                                    {
                                        measurement = "unité(s)";
                                    }
                                    else if (measurement == "g")
                                    {
                                        measurement = "g";
                                    }
                                    else if (measurement == "kg")
                                    {
                                        measurement = "kg";
                                    }
                                    else if (measurement == "ml")
                                    {
                                        measurement = "ml";
                                    }
                                    else if (measurement == "l")
                                    {
                                        measurement = "l";
                                    }
                                    else if (measurement == "cup")
                                    {
                                        measurement = "tasses";
                                    }
                                    else if (measurement == "tbsp")
                                    {
                                        measurement = "c. à soupe";
                                    }
                                    else if (measurement == "tsp")
                                    {
                                        measurement = "c. à café";
                                    }

                                    <li class="recipe-accordion-item">
                                        <div class="recipe-accordion-content">
                                            <input type="checkbox" id="ingredient-@i" />
                                            <p>
                                                <strong>[@ingredient.Quantity @measurement]</strong> @ingredient.Name
                                            </p>
                                        </div>
                                    </li>
                                    i++;
                                }
                            </ul>
                        }
                        else
                        {
                            <p>Aucun ingrédient disponible.</p>
                        }
                    </div>


                    <button class="recipe-accordion">Étapes</button>
                    <div class="recipe-accordion-container">
                        @if (Model.RecipeSteps != null && Model.RecipeSteps.Any())
                        {
                            <ul class="recipe-accordion-list">
                                @{
                                    int i = 0;
                                }
                                @foreach (var steps in Model.RecipeSteps)
                                {
                                    <li class="recipe-accordion-item">
                                        <div class="recipe-accordion-content">
                                            <input type="checkbox" id="ingredient-@i" />
                                            <p><strong>@steps.StepNumber.</strong> @steps.Description</p>
                                        </div>
                                    </li>
                                    i++;
                                }
                            </ul>
                        }
                        else
                        {
                            <p>Aucun étapes disponible.</p>
                        }
                    </div>
                </div>

                <ul class="message-options u-flex u-space-between">
                    <li class="message-options-item">
                        <label>
                            <button class="icon-button comment" onclick="event.stopPropagation(); toggleCommentBox('@Model.Id', 'recipe');"><span class="icon fa-regular fa-comment"></span></button>
                            <span class="text"></span>
                        </label>
                    </li>
                    <li class="message-options-item">
                        <label>
                            @if (Model.Reposts.Any(l => l.UserId == _userId))
                            {
                                <button class="icon-button repost" id="repost-btn-@Model.Id" onclick="event.stopPropagation(); toggleRecipeRepost('@Model.Id')"><span id="repost-text-@Model.Id" class="icon fa-solid fa-retweet reposted"></span></button>
                            }
                            else
                            {
                                <button class="icon-button repost" id="repost-btn-@Model.Id" onclick="event.stopPropagation(); toggleRecipeRepost('@Model.Id')"><span id="repost-text-@Model.Id" class="icon fa-solid fa-retweet"></span></button>
                            }
                            <span class="text">@Model.Reposts.Count()</span>
                        </label>
                    </li>
                    <li class="message-options-item">
                        <label>
                            @if (Model.Likes.Any(l => l.UserId == _userId))
                            {
                                <button class="icon-button like" id="like-btn-@Model.Id" onclick="event.stopPropagation(); toggleRecipeLike('@Model.Id')"><span id="like-text-@Model.Id" class="icon fa-solid fa-heart liked"></span></button>
                            }
                            else
                            {
                                <button class="icon-button like" id="like-btn-@Model.Id" onclick="event.stopPropagation(); toggleRecipeLike('@Model.Id')"><span id="like-text-@Model.Id" class="icon fa-regular fa-heart"></span></button>
                            }
                            <span class="text likes-count">@Model.Likes.Count()</span>
                        </label>
                    </li>
                    <li class="message-options-item">
                        <label>
                            <button class="icon-button" onclick="event.stopPropagation();"><span class="icon">🔗</span></button>
                            <span class="text"></span>
                        </label>
                    </li>
                </ul>
                @* Boîte de commentaires *@
                <!--<div class="comment-box u-hide" id="comment-box-@Model.Id">
                    <textarea class="comment-text-area" id="commentText-@Model.Id" placeholder="Écrivez un commentaire..."></textarea>
                    <button type="button" class="common-button" onclick="submitComment('@Model.Id', 'recipe')">
                        <span class="text">Commenter</span>
                    </button>
                </div>-->    
            </article>

        </li>
    </ul>
    @* Boîte de commentaires *@
    <section class="comment-message-box" id="comment-box-@Model.Id">
        <div class="profile-image-wrap">
            <img class="profile-image" src="@Url.Action("Photo", "Account")" alt="">
        </div>
        <div class="message-box-content">
            <textarea class="message-box-text-area" id="commentText-@Model.Id" placeholder="Écrivez un commentaire..."></textarea>
            @*@Html.TextAreaFor(p => p.Text, new { @id = "postText", @class = "message-box-text-area", @placeholder = "Postez votre réponse ?" })*@
            @*<button type="button" id="remove-preview" class="remove-preview-button u-hide">&times;</button>*@
            @*<img id="preview-content" class="content-image" src="" alt="">*@
            <p class="message-alert" id="message-alert"></p>
        </div>
        <nav class="message-box-nav u-flex">
            @*<ul class="u-flex">
                    <li>
                        <button type="button" class="icon-button" onclick="document.getElementById('file-upload').click();">
                            <span class="icon"><i class="fas fa-upload"></i></span>
                        </button>
                        <input type="file" id="file-upload" style="display: none;" />
                    </li>
                </ul>*@
            <button type="button" class="common-button u-margin-start-auto" onclick="submitComment('@Model.Id', 'recipe')"><span class="text">Publier</span></button>
        </nav>
    </section>
    <div style="margin-bottom:15%;" id="commentContainer">
        @*PARTIAL COMMENT*@
    </div>
    <div id="reviewsModal" class="modal">

        <!-- Modal content -->
        <div class="modal-content">
            @using (Html.BeginForm("AddReview", "Recipe"))
            {
                @Html.AntiForgeryToken()
                <div style="display: flex; flex-direction: column; gap: 15px;">
                    <div style="display: flex; flex-direction: row; justify-content: space-between; align-items: center;">
                        <h2 class="text">Laissez un avis</h2>
                        <span class="close">&times;</span>
                    </div>

                    <!-- Star Rating -->
                    <input type="hidden" name="recipeId" value="@Model.Id" />
                    <div class="rating" style="max-width: fit-content; margin: 0 auto;">
                        <label>
                            <input type="radio" name="stars" value="1" />
                            <span class="icon">★</span>
                        </label>
                        <label>
                            <input type="radio" name="stars" value="2" />
                            <span class="icon">★</span>
                            <span class="icon">★</span>
                        </label>
                        <label>
                            <input type="radio" name="stars" value="3" />
                            <span class="icon">★</span>
                            <span class="icon">★</span>
                            <span class="icon">★</span>
                        </label>
                        <label>
                            <input type="radio" name="stars" value="4" />
                            <span class="icon">★</span>
                            <span class="icon">★</span>
                            <span class="icon">★</span>
                            <span class="icon">★</span>
                        </label>
                        <label>
                            <input type="radio" name="stars" value="5" />
                            <span class="icon">★</span>
                            <span class="icon">★</span>
                            <span class="icon">★</span>
                            <span class="icon">★</span>
                            <span class="icon">★</span>
                        </label>
                    </div>

                    <!-- Validation Summary -->
                    <div style="display: flex; justify-content: center; margin-top: 10px;">
                        @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                    </div>

                    <!-- Action Buttons -->
                    <div style="display: flex; justify-content: flex-end; gap: 10px; margin-top: 20px;">
                        <button type="button" class="btn btn-back pointer" onclick="closeModal();">Annuler</button>
                        <button class="btn btn-success pointer" type="submit">Envoyer</button>
                    </div>
                </div>
            }
        </div>
    </div>





}
else
{
    <p>La recette est indisponible</p>
}
@section Scripts
{
    <script>
        let postPanelUpdater = new PartialRefresh("@Url.Action("_PartialComments", new RouteValueDictionary(new {id = Model.Id}))", "commentContainer", 30000);

        var modal = document.getElementById("reviewsModal");
        var closeBtn = document.getElementsByClassName("close")[0];

        function closeModal() {
            modal.style.display = "none";
            resetModalContent();
        }

        closeBtn.onclick = function () {
            closeModal();
        };

        function resetModalContent() {
            var radioButtons = document.getElementsByName("stars");

            for (var i = 0; i < radioButtons.length; i++) {
                radioButtons[i].checked = false;
            }
            if (radioButtons.length > 0) {
                radioButtons[0].checked = true;
            }
        }

        document.addEventListener("DOMContentLoaded", function () {
            var radioButtons = document.getElementsByName("stars");
            var modal = document.getElementById("reviewsModal");
            var btn = document.getElementById("reviewBtn"); // Ensure this button exists in your layout.
            var closeBtn = document.getElementsByClassName("close")[0];

            window.onclick = function (event) {
                if (event.target == modal) {
                    closeModal();
                }
            };

            btn.onclick = function () {
                modal.style.display = "block";
                radioButtons[0].checked = true;
            };
        });


        function toggleRecipeLike(recipeId) {
            const likeButton = document.getElementById(`like-btn-${recipeId}`);
            const likeText = document.getElementById(`like-text-${recipeId}`);
                const likesCountSpan = likeButton.nextElementSibling;

                $.ajax({
                    url: '@Url.Action("ToggleLike", "Recipe")',
                    type: 'POST',
                    data: { recipeId: recipeId },
                    success: function(response) {
                        if (response.success) {
                            likeText.classList.toggle('liked');
                            likeText.classList.remove('fa-regular')
                            likeText.classList.add('fa-solid')
                            likesCountSpan.innerText = response.likesCount;
                        } else {
                            likeText.classList.toggle('liked');
                            likeText.classList.remove('fa-solid')
                            likeText.classList.add('fa-regular')
                            likesCountSpan.innerText = response.likesCount;
                        }
                    },
                    error: function(xhr, status, error) {
                        console.error(`Failed to toggle like. Try again later.`);
                    }
                });
             }
        function toggleCommentBox(id, type) {
            const commentBox = document.getElementById(`comment-box-${id}`);
            if (commentBox.classList.contains('u-hide')) {
                commentBox.classList.remove('u-hide');
            } else {
                commentBox.classList.add('u-hide');
            }
        }

        function submitComment(id, type) {
            const commentText = document.getElementById(`commentText-${id}`).value;
            if (!commentText) {
                alert('Veuillez entrer un commentaire.');
                return;
            }

            let data = {
             comment: commentText
            };

            let url = '';
             if (type === 'recipe') {
                data.recipeId = id;
                 url = '@Url.Action("AddComment", "Recipe")';
            } else if (type === 'post') {
                data.postId = id;
             url = '@Url.Action("AddComment", "Post")';
            }

            $.ajax({
                url: url,
                type: 'POST',
                data: data,
                success: function(response) {
                    if (response.success) {
                        /*alert('Commentaire ajouté avec succès !');*/
                        document.getElementById(`commentText-${id}`).value = '';
                        /*toggleCommentBox(id, type);*/
                        postPanelUpdater.refresh()
                    } else {
                        alert('Une erreur est survenue. Veuillez réessayer.');
                    }
                },
                error: function(xhr, status, error) {
                    console.error('Erreur lors de l\'ajout du commentaire :', error);
                }
            });
        }
        function submitCommentAnswer(id) {
            const commentText = document.getElementById(`commentText-${id}`).value;
            if (!commentText) {
                alert('Veuillez entrer un commentaire.');
                return;
            }

            let data = {
            recipeCommentId: id,
            comment: commentText
            };

            $.ajax({
                url: '@Url.Action("AnswerComment", "Recipe")',
                type: 'POST',
                data: data,
                success: function(response) {
                    if (response.success) {
                        /*alert('Commentaire ajouté avec succès !');*/
                        document.getElementById(`commentText-${id}`).value = '';
                        /*toggleCommentBox(id, type);*/
                        postPanelUpdater.refresh()
                    } else {
                        alert('Une erreur est survenue. Veuillez réessayer.');
                    }
                },
                error: function(xhr, status, error) {
                    console.error('Erreur lors de l\'ajout du commentaire :', error);
                }
            });
        }

        function toggleFeedItemDropdown(button) {
            var dropdown = button.nextElementSibling;
            dropdown.style.display = dropdown.style.display === 'block' ? 'none' : 'block';

            document.addEventListener('click', function (event) {
                if (!button.contains(event.target) && !dropdown.contains(event.target)) {
                    dropdown.style.display = 'none';
                }
            });
        }

        var acc = document.getElementsByClassName("recipe-accordion");
        for (var i = 0; i < acc.length; i++) {
            acc[i].addEventListener("click", function () {
                this.classList.toggle("active");
                var panel = this.nextElementSibling;
                if (panel.style.maxHeight) {
                    panel.style.maxHeight = null;
                } else {
                    panel.style.maxHeight = panel.scrollHeight + "px";
                }
            });
        }

        function submitRecipeAnswer(id) {
            const commentText = document.getElementById(`commentText-${id}`).value;
            if (!commentText) {
                alert('Veuillez entrer un commentaire.');
                return;
            }
            let data = {
            recipeCommentId: id,
            comment: commentText
            };

            $.ajax({
                url: '@Url.Action("AnswerComment", "Recipe")',
                type: 'POST',
                data: data,
                success: function(response) {
                    if (response.success) {
                        /*alert('Commentaire ajouté avec succès !');*/
                        document.getElementById(`commentText-${id}`).value = '';
                        /*toggleCommentBox(id, type);*/
                        postPanelUpdater.refresh()
                    } else {
                        alert('Une erreur est survenue. Veuillez réessayer.');
                    }
                },
                error: function(xhr, status, error) {
                    console.error('Erreur lors de l\'ajout du commentaire :', error);
                }
            });
        }
    </script>
}



