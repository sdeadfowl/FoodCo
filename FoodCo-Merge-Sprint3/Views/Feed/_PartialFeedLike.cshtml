@{
    Layout = null;
    @*@model IEnumerable<FoodCo.Models.Post>*@
    @model List<object>
    var _userId = Session["currentUserId"]?.ToString();
}

<section class="feed">
    <ul class="feed-list" id="feed-list">
        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                if (item is FoodCo.Models.Post)
                {
                    var p = (FoodCo.Models.Post)item;

                    <li class="feed-item pointer">
                        <article class="foodco-item">
                            <img class="profile-image" src="@(p.User.ProfilePicturePath != null ? p.User.ProfilePicturePath : "default-profile-image-base64")" alt="profile-image">
                            <header class="foodco-item-info u-flex">
                                <a class="foodco-item-info-user" href="@Url.Action("Profile","Account",new {username = p.User.UserName})">
                                    <span class="common-title">@p.User.Name</span>
                                    <span class="usercode">@p.User.UserName.ToLower()</span>
                                </a>
                                <time datetime="@p.Date.ToString("yyyy/MM/dd")">
                                    @p.Date.ToString("MM/dd/yyyy", System.Globalization.CultureInfo.InvariantCulture)
                                </time>
                                @if (p.UserId == _userId)
                                {
                                    <div class="feed-item-options-dropdown u-flex u-margin-start-auto" style="position: relative;">
                                        <button class="icon-button" style="--icon-button-size:27px;" onclick="toggleFeedItemDropdown(this)">
                                            <span class="icon fa fas fa-ellipsis-h"></span>
                                        </button>
                                        <ul class="feed-item-dropdown-menu feed-item-options" style="position: absolute; right: 0; top: 100%; display: none;">
                                            <li class="feed-item-dropdown-item">
                                                <a href="@Url.Action("Details", "Post", new { id = p.Id })">Afficher les détails</a>
                                            </li>
                                            <li class="feed-item-dropdown-item">
                                                <a href="@Url.Action("Edit", "Post", new { id = p.Id })">Modifier</a>
                                            </li>
                                            <li class="feed-item-dropdown-item">
                                                @using (Html.BeginForm("Delete", "Post", FormMethod.Post, new { @onsubmit = "return confirm('Êtes-vous sûr de vouloir supprimer ce post?');" }))
                                                {
                                                    @Html.AntiForgeryToken()
                                                    @Html.Hidden("id", p.Id)
                                                    <button type="submit" class="dropdown-link">Supprimer</button>
                                                }
                                            </li>
                                        </ul>
                                    </div>
                                }
                                else
                                {
                                    <div class="feed-item-options-dropdown u-flex u-margin-start-auto" style="position: relative;">
                                        <button class="icon-button" style="--icon-button-size:27px;" onclick="toggleFeedItemDropdown(this)">
                                            <span class="icon fa fas fa-ellipsis-h"></span>
                                        </button>
                                        <ul class="feed-item-dropdown-menu feed-item-options" style="position: absolute; right: 0; top: 100%; display: none;">
                                            <li class="feed-item-dropdown-item">
                                                <a href="@Url.Action("Details", "Post", new { id = p.Id })">Afficher les détails</a>
                                            </li>
                                        </ul>
                                    </div>
                                }

                                @*<button class="icon-button u-flex u-margin-start-auto" style="--icon-button-size:27px;"><span class="icon icon-arrow-down u-margin-auto"></span></button>*@
                            </header>
                            <div class="common-content" onclick="location.href = '@Url.Action("Details", "Post", new { id = p.Id })'">
                                <p>@p.Text</p>
                                @if (p.Content != null)
                                {
                                    <img class="content-image" src="data:image/jpeg;base64,@Convert.ToBase64String(p.Content)" alt="Post content">
                                }
                            </div>
                            <ul class="message-options u-flex u-space-between">
                                <li class="message-options-item">
                                    <label>
                                        <button class="icon-button comment" onclick="event.stopPropagation(); toggleCommentBox('@p.Id', 'post');"><span class="icon fa-regular fa-comment"></span></button>
                                        <span class="text"></span>
                                    </label>
                                </li>
                                <li class="message-options-item">
                                    <label>
                                        @if (p.Likes.Any(l => l.UserId == _userId))
                                        {
                                            <button class="icon-button like" id="like-btn-@p.Id" onclick="event.stopPropagation(); togglePostLike('@p.Id')"><span id="like-text-@p.Id" class="icon fa-solid fa-heart liked"></span></button>
                                        }
                                        else
                                        {
                                            <button class="icon-button like" id="like-btn-@p.Id" onclick="event.stopPropagation(); togglePostLike('@p.Id')"><span id="like-text-@p.Id" class="icon fa-regular fa-heart"></span></button>
                                        }
                                        <span class="text likes-count">@p.Likes.Count()</span>
                                    </label>
                                </li>
                                <li class="message-options-item">
                                    <label>

                                        <button class="icon-button like" id="like-btn-@p.Id" onclick="event.stopPropagation(); toggleRecipeLike('@p.Id')"><span id="like-text-@p.Id" class="icon fa-solid fa-heart liked"></span></button>


                                    </label>
                                </li>

                                <li class="message-options-item">
                                    <label>
                                        <button class="icon-button" onclick="event.stopPropagation(); CopierLienPublication(@p.Id, false)"><span class="icon">🔗</span></button>
                                        <span class="text"></span>
                                    </label>
                                </li>
                            </ul>
                            @* Boîte de commentaires *@
                            @*<div class="comment-box u-hide" id="comment-box-@p.Id">
                                    <textarea class="comment-text-area" id="commentText-@p.Id" placeholder="Écrivez un commentaire..."></textarea>
                                    <button type="button" class="common-button" onclick="submitComment('@p.Id', 'post')">
                                        <span class="text">Commenter</span>
                                    </button>
                                </div>*@
                        </article>
                        <section class="comment-message-box u-hide-border u-hide" onlick="event.stopPropagation();" id="comment-box-@p.Id">
                            <div class="profile-image-wrap">
                                <img class="profile-image" src="@Url.Action("Photo", "Account")" alt="">
                            </div>
                            <div class="message-box-content">
                                <textarea class="message-box-text-area" id="commentText-@p.Id" placeholder="Écrivez un commentaire..."></textarea>
                                @*@Html.TextAreaFor(p => p.Text, new { @id = "postText", @class = "message-box-text-area", @placeholder = "Postez votre réponse ?" })*@
                                <button type="button" id="remove-preview" class="remove-preview-button u-hide">&times;</button>
                                @*<img id="preview-content" class="content-image" src="" alt="">*@
                                <p class="message-alert" id="message-alert-@p.Id"></p>
                            </div>
                            <nav class="message-box-nav u-flex">
                                @*<ul class="u-flex">
                                        <li>
                                            <button type="button" class="icon-button" onclick="document.getElementById('file-upload').click();">
                                                <span class="icon"><i class="fas fa-upload"></i></span>
                                            </button>
                                            <input type="file" id="file-upload" style="display: none;" />
                                        </li>
                                    </ul>*@
                                <button type="button" class="common-button u-margin-start-auto" onclick="submitComment('@p.Id', 'post')"><span class="text">Publier</span></button>
                            </nav>
                        </section>
                    </li>
                }
                else if (item is FoodCo.Models.Recipe)
                {
                    var r = (FoodCo.Models.Recipe)item;

                    <li class="feed-item pointer">

                        <article class="foodco-item">
                            <img class="profile-image" src="@(r.User.ProfilePicturePath != null ? r.User.ProfilePicturePath : "default-profile-image-base64")" alt="profile-image">
                            <header class="foodco-item-info u-flex">
                                <a class="foodco-item-info-user" href="@Url.Action("Profile","Account",new {username = r.User.UserName})">
                                    <span class="common-title">@r.User.Name</span>
                                    <span class="usercode">@@@r.User.UserName.ToLower()</span>
                                </a>
                                <time datetime="@r.Date.ToString("yyyy/MM/dd")">
                                    @r.Date.ToString("MM/dd/yyyy", System.Globalization.CultureInfo.InvariantCulture)
                                </time>


                                <div class="u-flex u-left-margin-auto" style="align-items: center;">
                                    @*<div class="u-flex u-left-margin-auto" style="align-items: center; flex-direction: column; gap:0.5em;">
                                            <div class="u-flex" style="align-items: center;">
                                                @for (int f = 0; f < (int)Math.Floor(Math.Round(4.5, 1)); f++)
                                                {
                                                    <span class="icon-stars reset-spacing fa fa-star checked"></span>
                                                }
                                                @if (4.5 % 1 != 0)
                                                {
                                                    <span class="icon-stars reset-spacing fa fa-star-half"></span>
                                                }
                                                <p class="reset-spacing total-reviews">(512)</p>
                                            </div>
                                            <div class="tag-container u-flex u-left-margin-auto">
                                                <p class="tag reset-spacing">
                                                    @(string.IsNullOrEmpty(r.Tag) ? string.Empty : char.ToUpper(r.Tag[0]) + r.Tag.Substring(1))
                                                </p>
                                            </div>
                                        </div>*@
                                    @if (r.UserId == _userId)
                                    {
                                        <div class="feed-item-options-dropdown u-flex u-margin-start-auto" style="position: relative;">
                                            <button class="icon-button" style="--icon-button-size:27px;" onclick="toggleFeedItemDropdown(this)">
                                                <span class="icon fa fas fa-ellipsis-h"></span>
                                            </button>
                                            <ul class="feed-item-dropdown-menu feed-item-options" style="position: absolute; right: 0; top: 100%; display: none;">
                                                <li class="feed-item-dropdown-item">
                                                    <a href="@Url.Action("Details", "Recipe", new { id = r.Id })">Afficher les détails</a>
                                                </li>
                                                <li class="feed-item-dropdown-item">
                                                    <a href="@Url.Action("Edit", "Recipe", new { id = r.Id })">Modifier</a>
                                                </li>
                                                <li class="feed-item-dropdown-item">
                                                    @using (Html.BeginForm("Delete", "Recipe", FormMethod.Post, new { @onsubmit = "return confirm('Êtes-vous sûr de vouloir supprimer cette recette?');" }))
                                                    {
                                                        @Html.AntiForgeryToken()
                                                        @Html.Hidden("id", r.Id)
                                                        <button type="submit" class="dropdown-link">Supprimer</button>
                                                    }
                                                </li>
                                            </ul>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="feed-item-options-dropdown u-flex u-margin-start-auto" style="position: relative;">
                                            <button class="icon-button" style="--icon-button-size:27px;" onclick="toggleFeedItemDropdown(this)">
                                                <span class="icon fa fas fa-ellipsis-h"></span>
                                            </button>
                                            <ul class="feed-item-dropdown-menu feed-item-options" style="position: absolute; right: 0; top: 100%; display: none;">
                                                <li class="feed-item-dropdown-item">
                                                    <a href="@Url.Action("Details", "Recipe", new { id = r.Id })">Afficher les détails</a>
                                                </li>
                                            </ul>
                                        </div>
                                    }
                                    @*<div>
                                            <button class="icon-button u-flex u-left-margin-auto" style="--icon-button-size:27px;"><span class="icon icon-arrow-down u-margin-auto"></span></button>
                                        </div>*@
                                </div>

                            </header>
                            <div class="common-content" onclick="location.href = '@Url.Action("Details", "Recipe", new { id = r.Id })' ">
                                <div class="review-container">
                                    <div class="review-options">
                                        @if (r.ReviewCount() < 1)
                                        {
                                            <p class="reset-spacing total-reviews">Aucun review</p>
                                        }
                                        else
                                        {
                                            <div>
                                                @for (int f = 0; f < (int)Math.Floor(r.AverageRating()); f++)
                                                {
                                                    <span class="icon-stars reset-spacing fa fa-star checked"></span>
                                                }
                                                @if (r.AverageRating() - Math.Floor(r.AverageRating()) >= 0.5)
                                                {
                                                    <span class="icon-stars reset-spacing fa fa-star-half"></span>
                                                }
                                            </div>
                                            <p class="reset-spacing total-reviews">(@r.ReviewCount())</p>
                                        }
                                        <div class="tag-container u-flex u-left-margin-auto">
                                            <p class="tag reset-spacing">
                                                @(string.IsNullOrEmpty(r.Tag) ? string.Empty : char.ToUpper(r.Tag[0]) + r.Tag.Substring(1))
                                            </p>
                                        </div>
                                    </div>
                                    @*<a class="review-link text" title="Évaluer cette recette">Évaluer cette recette</a>*@
                                </div>

                                <h2>@r.Name</h2>
                                <p>@r.Description</p>


                                @*@if (r.ContentPath != null)
                                    {
                                        <img class="content-image" src="@r.ContentPath" alt="Post content">
                                    }*@
                                @if (r.ContentPath != null)
                                {
                                    var fileExtension = System.IO.Path.GetExtension(r.ContentPath).ToLower();
                                    if (fileExtension == ".jpg" || fileExtension == ".jpeg" || fileExtension == ".png" || fileExtension == ".gif")
                                    {
                                        <img class="content-image" src="@r.ContentPath">
                                    }
                                    else if (fileExtension == ".mp4" || fileExtension == ".webm" || fileExtension == ".ogg")
                                    {
                                        <video class="content-video" controls onclick="event.stopPropagation()">
                                            <source src="@r.ContentPath" type="video/@fileExtension.Substring(1)">
                                        </video>
                                    }
                                }
                            </div>
                            <ul class="message-options u-flex u-space-between">
                                <li class="message-options-item">
                                    <label>
                                        <button class="icon-button comment" onclick="event.stopPropagation(); toggleCommentBox('@r.Id', 'recipe');"><span class="icon fa-regular fa-comment"></span></button>
                                        <span class="text"></span>
                                    </label>
                                </li>
                                <li class="message-options-item">
                                    <label>
                                        @if (r.Reposts.Any(l => l.UserId == _userId))
                                        {
                                            <button class="icon-button repost" id="repost-btn-@r.Id" onclick="event.stopPropagation(); toggleRecipeRepost('@r.Id')"><span id="repost-text-@r.Id" class="icon fa-solid fa-retweet reposted"></span></button>
                                        }
                                        else
                                        {
                                            <button class="icon-button repost" id="repost-btn-@r.Id" onclick="event.stopPropagation(); toggleRecipeRepost('@r.Id')"><span id="repost-text-@r.Id" class="icon fa-solid fa-retweet"></span></button>
                                        }
                                        <span class="text">@r.Reposts.Count()</span>
                                    </label>
                                </li>
                                <li class="message-options-item">
                                    <label>
                                        @if (r.Likes.Any(l => l.UserId == _userId))
                                        {
                                            <button class="icon-button like" id="like-btn-@r.Id" onclick="event.stopPropagation(); toggleRecipeLike('@r.Id')"><span id="like-text-@r.Id" class="icon fa-solid fa-heart liked"></span></button>
                                        }
                                        else
                                        {
                                            <button class="icon-button like" id="like-btn-@r.Id" onclick="event.stopPropagation(); toggleRecipeLike('@r.Id')"><span id="like-text-@r.Id" class="icon fa-regular fa-heart"></span></button>
                                        }
                                        <span class="text likes-count">@r.Likes.Count()</span>
                                    </label>
                                </li>
                                <li class="message-options-item">
                                    <label>
                                        <button class="icon-button" onclick="event.stopPropagation(); CopierLienPublication(@r.Id, true)"><span class="icon">🔗</span></button>
                                        <span class="text"></span>
                                    </label>
                                </li>
                            </ul>
                            @* Boîte de commentaires *@
                            @*<div class="comment-box u-hide" id="comment-box-@r.Id" onclick="event.stopPropagation();">
                                    <textarea class="comment-text-area" id="commentText-@r.Id" placeholder="Écrivez un commentaire..."></textarea>
                                    <button type="button" class="common-button" onclick="submitComment('@r.Id', 'recipe')">
                                        <span class="text">Commenter</span>
                                    </button>
                                </div>*@
                        </article>
                        <section class="comment-message-box u-hide-border u-hide" onlick="event.stopPropagation();" id="comment-box-@r.Id">
                            <div class="profile-image-wrap">
                                <img class="profile-image" src="@Url.Action("Photo", "Account")" alt="">
                            </div>
                            <div class="message-box-content">
                                <textarea class="message-box-text-area" id="commentText-@r.Id" placeholder="Écrivez un commentaire..."></textarea>
                                @*@Html.TextAreaFor(p => p.Text, new { @id = "postText", @class = "message-box-text-area", @placeholder = "Postez votre réponse ?" })*@
                                <button type="button" id="remove-preview" class="remove-preview-button u-hide">&times;</button>
                                @*<img id="preview-content" class="content-image" src="" alt="">*@
                                <p class="message-alert" id="message-alert-@r.Id"></p>
                            </div>
                            <nav class="message-box-nav u-flex">
                                @*<ul class="u-flex">
                                        <li>
                                            <button type="button" class="icon-button" onclick="document.getElementById('file-upload').click();">
                                                <span class="icon"><i class="fas fa-upload"></i></span>
                                            </button>
                                            <input type="file" id="file-upload" style="display: none;" />
                                        </li>
                                    </ul>*@
                                <button type="button" class="common-button u-margin-start-auto" onclick="submitComment('@r.Id', 'recipe')"><span class="text">Publier</span></button>
                            </nav>
                        </section>
                    </li>
                }
            }

        }
        @if (Model.Count <= 0)
        {
            <div class="blocked">
                Aucune Publication
            </div>
            <div class="content fa fa-camera"></div>
        }

        @*else
            {
                <li>No posts available.</li>
            }*@
    </ul>
</section>
