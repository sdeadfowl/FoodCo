@using FoodCo.Models


@{
    ApplicationDbContext db = new ApplicationDbContext();
    var _userId = Session["currentUserId"]?.ToString();
    var admin = db.Admin;
    var isAdmin = false;

    foreach (var userAdmin in admin)
    {
        if (userAdmin.UserId == _userId && userAdmin.IsAdmin == true)
        {
            isAdmin = true;
        }
    }
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_LoggedInLayout.cshtml";
    @model Tuple<IEnumerable<FoodCo.Models.Post>, FoodCo.Models.Post>
}


@if (!isAdmin)
{

    @*HEADER*@
    @*----------------------------------------------------------START OF MAIN------------------------------------------------------------*@
    <header class="main-header">
        <button class="icon-button icon-back u-hide"><span class="icon">←</span></button>
        <div class="main-header-content">
            <h1 class="section-title">FoodCo</h1>
        </div>
        <button class="icon-button u-margin-start-auto" aria-label="Top foodcos on"><span class="icon">✨</span></button>
    </header>

    @*PUBLICATION BOX*@
    using (Html.BeginForm("Create", "Post", FormMethod.Post))
    {
        @Html.AntiForgeryToken()
        <section class="message-box">
            <div class="profile-image-wrap">
                <img class="profile-image" src="@User.Identity.GetProfilePicturePath()" alt="">
            </div>
            <div class="message-box-content">
                @Html.TextAreaFor(p => p.Item2.Text, new { @id = "postText", @class = "message-box-text-area", @placeholder = "Quoi de neuf ?" })
                <button type="button" id="remove-preview" class="remove-preview-button u-hide">&times;</button>
                <img id="preview-content" class="content-image" src="" alt="">
                <div class="char-counter">250 caractères restants</div>
                <p class="message-alert" id="message-alert"></p>
            </div>
            <nav class="message-box-nav u-flex">
                <ul class="u-flex">
                    <li>
                        <button type="button" class="icon-button" onclick="document.getElementById('file-upload').click();">
                            <span class="icon"><i class="fas fa-upload"></i></span>
                        </button>
                        <input type="file" id="file-upload" style="display: none;" />
                    </li>
                </ul>
                <button type="button" class="common-button u-margin-start-auto" onclick="submitPost()"><span class="text">Publier</span></button>
            </nav>
        </section>
    }



    @*FEED*@
    <div id="feedContainer">
        @*@Html.Partial("_PartialFeed", Model)*@
    </div>
    <div id="loading" class="loading-indicator" style="display:none;">
        Loading more posts...
    </div>
}

