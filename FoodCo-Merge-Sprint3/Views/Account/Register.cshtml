@model FoodCo.Models.RegisterViewModel
@{
    ViewBag.Title = "Register";
}

<div class="register-container">
    @using (Html.BeginForm("Register", "Account", FormMethod.Post, new { role = "form" }))
    {
        @Html.AntiForgeryToken()

        <div class="title col-md-12">
            <h1 class="title-text">Inscription</h1>
        </div>
        <div class="row">
            <div class="col-md-12">
                @Html.TextBoxFor(m => m.UserName, new { @class = "form-control", placeholder = "Nom d'utilisateur" })
            </div>
        </div>
        <div class="row">
            @*@Html.LabelFor(m => m.Name, new { @class = "col-md-2 col-form-label" })*@
            <div class="col-md-12">
                @Html.TextBoxFor(m => m.Name, new { @class = "form-control", placeholder = "Prénom" })
            </div>
        </div>
        <div class="row">
            <div class="col-md-12">
                @Html.TextBoxFor(m => m.Lastname, new { @class = "form-control", placeholder = "Nom" })
            </div>
        </div>
        <div class="row">
            <div class="col-md-12">
                @Html.TextBoxFor(m => m.Email, new { @class = "form-control", placeholder = "Courriel" })
            </div>
        </div>
        <div class="row">
            <div class="col-md-12">
                @Html.PasswordFor(m => m.Password, new { @class = "form-control", placeholder = "Mot de passe" })
            </div>
        </div>
        <div class="row">
            <div class="col-md-12">
                @Html.PasswordFor(m => m.ConfirmPassword, new { @class = "form-control", placeholder = "Confirmation" })
            </div>
        </div>
        <div class="row">
            <div class="col-md-12">
                <input type="submit" value="S'inscrire" class="btn btn-global main-color submit" />
            </div>
        </div>
        <div class="options col-md-12">
            <span class="options-text">ou</span>
        </div>
        <div class="row">
            <div class="col-md-12">
                <input value="Continuer avec Google" class="btn btn-global google-submit" />
            </div>
        </div>
        @Html.ValidationSummary("", new { @class = "text-danger" })
        <p class="options-text">
            @Html.ActionLink("Déjà inscrit ?", "Login")

        </p>
    }
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
    @Styles.Render("~/Content/account/register.css")
}

