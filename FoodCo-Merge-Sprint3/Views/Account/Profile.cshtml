@section Scripts{
    <script>

            document.getElementById("Private").onclick = function () { PrivateClick(document.getElementById("Private")) }
            document.getElementById("Public").onclick = function () { PrivateClick(document.getElementById("Public")) }


        function PrivateClick(id) {
            if (id.value == "Private") {
                $.ajax({
                    url: '@Url.Action("Private", "Block", new {id = Model.Id})',
                    type: 'POST',
                    success: function (response) {
                        alert('Account private Successfully.');
                        window.location.reload();

                    },
                    error: function (xhr, status, error) {
                        console.error('Failed to make user private:', error);
                        alert('An error occurred. Please try again later.');
                    }
                });
            }
            else if (id.value == "Public") {

                $.ajax({
                    url: '@Url.Action("Public", "Block", new {id = Model.Id})',
                    type: 'POST',
                    success: function (response) {
                        alert('Account public Successfully.');
                        window.location.reload();
                    },
                    error: function (xhr, status, error) {
                        console.error('Failed to make user public:', error);
                        alert('An error occurred. Please try again later.');
                    }
                });
            }
        }

                let feedPanelUpdater = new PartialRefresh("@Url.Action("_PartialFeedProfile", "Feed", new {UserId = Model.Id})", "postContainer", 30000);
                    document.getElementById("publication").onclick = function () { onclickSelect(document.getElementById("publication")) }
                    document.getElementById("aime").onclick = function () { onclickSelect(document.getElementById("aime")) }
                    document.getElementById("livre").onclick = function () { onclickSelect(document.getElementById("livre")) }
        function onclickSelect(id) {
            if (id == document.getElementById("publication")) {
                let feedPanelUpdater = new PartialRefresh("@Url.Action("_PartialFeedProfile", "Feed", new { UserId = Model.Id })", "postContainer", 30000);
                var element = document.getElementById("aime");
                element.classList.remove("is-selected");
                element = document.getElementById("livre");
                element.classList.remove("is-selected");
                id.classList.add("is-selected");
            }
            else if (id == document.getElementById("aime")) {
                let feedPanelUpdate = new PartialRefresh("@Url.Action("_PartialFeedLike", "Feed", new { UserId = Model.Id })", "postContainer", 30000);
                var element = document.getElementById("publication");
                element.classList.remove("is-selected");
                element = document.getElementById("livre");
                element.classList.remove("is-selected");
                id.classList.add("is-selected");
            }
            else if (id == document.getElementById("livre")) {
                let feedPanelUpdate = new PartialRefresh("@Url.Action("_PartialFeedBook", "Feed", new { userId = Model.Id })", "postContainer", 30000);
                var element = document.getElementById("publication");
                element.classList.remove("is-selected");
                element = document.getElementById("aime");
                element.classList.remove("is-selected");
                id.classList.add("is-selected");
                }
        }

        document.getElementById("Following").onclick = function () { FollowClick(document.getElementById("Following")) }
        document.getElementById("UnFollow").onclick = function () { FollowClick(document.getElementById("UnFollow")) }
        document.getElementById("FollowBack").onclick = function () { FollowClick(document.getElementById("FollowBack")) }


        function FollowClick(id) {
            if (id.value == "Following") {
                $.ajax({
                    url: '@Url.Action("Following", "Follow", new {id = Model.Id})',
                    type: 'POST',
                    success: function (response) {
                        alert('Followed Successfully.');
                        window.location.reload();
                    },
                    error: function (xhr, status, error) {
                        console.error('Failed to follow user:', error);
                        alert('An error occurred. Please try again later.');
                    }
                });
            }
            else if (id.value == "UnFollow") {

                $.ajax({
                    url: ' @Url.Action("UnFollow", "Follow", new {id = Model.Id})',
                    type: 'POST',
                    success: function (response) {
                        alert('Unfollowed Successfully.');
                        window.location.reload();
                    },
                    error: function (xhr, status, error) {
                        console.error('Failed to unfollow the user:', error);
                        alert('An error occurred. Please try again later.');
                    }
                });
            }
            else {
                $.ajax({
                    url: '@Url.Action("FollowBack", "Follow", new {id = Model.Id})',
                    type: 'POST',
                    success: function (response) {
                        alert('Followed Successfully.');
                        window.location.reload();
                    },
                    error: function (xhr, status, error) {
                        console.error('Failed to follow back the user:', error);
                        alert('An error occurred. Please try again later.');
                    }
                });
            }
        }


        document.getElementById("unBlock").onclick = function () { BlockClick(document.getElementById("unBlock")) }
        document.getElementById("Blocking").onclick = function () { BlockClick(document.getElementById("Blocking")) }

        function BlockClick(id) {
            if (id.value == "Blocking") {
                $.ajax({
                    url: '@Url.Action("Blocking", "Block", new {id = Model.Id})',
                    type: 'POST',
                    success: function (response) {
                        alert('Blocked Successfully.');
                        window.location.reload();

                    },
                    error: function (xhr, status, error) {
                        console.error('Failed to block user:', error);
                        alert('An error occurred. Please try again later.');
                    }
                });
            }
            else if (id.value == "unBlock") {

                $.ajax({
                    url: '@Url.Action("UnBlock", "Block", new {id = Model.Id})',
                    type: 'POST',
                    success: function (response) {
                        alert('Unblocked Successfully.');
                        window.location.reload();
                    },
                    error: function (xhr, status, error) {
                        console.error('Failed to unblock the user:', error);
                        alert('An error occurred. Please try again later.');
                    }
                });
            }
        }


    </script>
}
