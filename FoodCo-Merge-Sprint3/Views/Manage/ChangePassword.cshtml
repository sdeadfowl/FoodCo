@model FoodCo.Models.ChangePasswordViewModel
@{
    ViewBag.Title = "Modification de mot de passe";
    Layout = "~/Views/Shared/_LoggedInLayout.cshtml";
}

<header class="main-header">
    <button class="icon-button icon fa fa-arrow-left" onclick="window.history.back()"><span class="icon"></span></button>
    <div class="main-header-content">

        <h1 class="section-title">@ViewBag.Title</h1>
    </div>
    <button class="icon-button u-margin-start-auto" aria-label="Top foodcos on"><span class="icon">✨</span></button>
</header>

<main aria-labelledby="title" class="change-password-container" style="padding: 20rem;">
    @using (Html.BeginForm("ChangePassword", "Manage", FormMethod.Post, new { role = "form" }))
    {
        @Html.AntiForgeryToken()
        <div class="form-group" style="margin-bottom: 8rem;">
            <label for="OldPassword" style="display: block; font-size: 16rem; color: #666666; margin-bottom: 2rem;">Ancien mot de passe</label>
            @Html.PasswordFor(m => m.OldPassword, new { @class = "form-control", style = "width: 100%; padding: 5rem; border: 0.1rem solid #ddd; border-radius: 5rem;" })
        </div>

        <div class="form-group" style="margin-bottom: 8rem;">
            <label for="NewPassword" style="display: block; font-size: 16rem; color: #666666; margin-bottom: 2rem;">Nouveau mot de passe</label>
            @Html.PasswordFor(m => m.NewPassword, new { @class = "form-control", style = "width: 100%; padding: 5rem; border: 0.1rem solid #ddd; border-radius: 5rem;" })
        </div>

        <div class="form-group" style="margin-bottom: 8rem;">
            <label for="ConfirmPassword" style="display: block; font-size: 16rem; color: #666666; margin-bottom: 2rem;">Confirmer le mot de passe</label>
            @Html.PasswordFor(m => m.ConfirmPassword, new { @class = "form-control", style = "width: 100%; padding: 5rem; border: 0.1rem solid #ddd; border-radius: 5rem;" })
        </div>

        <button type="submit" style="width: 100%; padding: 7.5rem; background-color: var(--main-color); color: #ffffff; border: 1px solid var(--main-color); border-radius: 5rem; font-size: 16rem; font-weight: bold; cursor: pointer; margin-top: 10rem;">Enregistrer les modifications</button>
    }
</main>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
